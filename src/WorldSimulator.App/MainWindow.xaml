<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WorldSimulator.App.Views"
        Title="Симулятор мира MVP 0.1"
        Height="720"
        Width="1200">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="День:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Control.Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Час:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Control.Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="Состояние:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Control.SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Старт" Command="{Binding Control.StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Пауза" Command="{Binding Control.PauseCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Сброс" Command="{Binding Control.ResetCommand}" Width="90" Margin="0,0,16,0" ToolTip="Сбросить симуляцию к дню 1, часу 0 без перезапуска приложения"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Загрузить" Command="{Binding LoadCommand}" Width="110" Margin="0,0,8,0"/>
                <CheckBox Content="Показать маршруты"
                          IsChecked="{Binding Map.IsTradeRoutesOverlayVisible}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"/>
                <CheckBox Content="Debug: реальные пути караванов"
                          IsChecked="{Binding Map.IsLoadedRoutePathsDebugVisible}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"/>
                <ToggleButton Content="Редактор маршрутов" IsChecked="{Binding TradeRouteAuthoring.IsTradeRouteAuthoringModeEnabled}" Width="160"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <views:TradeRouteAuthoringPanelView Grid.Row="0" Grid.ColumnSpan="3"/>

            <views:WorldMapView Grid.Row="1"
                                Grid.Column="0"
                                DataContext="{Binding Map}"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <StackPanel Grid.Row="1" Grid.Column="2">
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding SimulationSummaryTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SimulationSummaryDayAndHour}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryCityState}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryFoodBalance}" ToolTip="{Binding FoodBalanceTooltip}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryActiveEvents}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryRandomEventsStatus}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedRegionName, StringFormat=Регион: {0}}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryLastImportantChange}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <views:SelectedCityPanelView/>
                <views:MapDebugPanelView DataContext="{Binding Map}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
