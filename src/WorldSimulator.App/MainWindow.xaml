<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WorldSimulator.App.Converters"
        Title="Симулятор мира MVP 0.1"
        Height="720"
        Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:MapMarkerCanvasLeftConverter x:Key="MapMarkerCanvasLeftConverter" />
        <conv:MapMarkerCanvasTopConverter x:Key="MapMarkerCanvasTopConverter" />
        <conv:TradeRoutePointsToPointCollectionConverter x:Key="TradeRoutePointsToPointCollectionConverter" />
        <conv:CaravanMarkerCanvasCoordinateConverter x:Key="CaravanMarkerCanvasCoordinateConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="День:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Час:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="Состояние:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Старт" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Пауза" Command="{Binding PauseCommand}" Width="90" Margin="0,0,16,0"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Загрузить" Command="{Binding LoadCommand}" Width="110"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid x:Name="MapContainer"
                      MouseLeftButtonDown="MapContainer_MouseLeftButtonDown"
                      SizeChanged="MapContainer_SizeChanged">
                    <Image x:Name="MapImage"
                           Source="/Assets/Maps/world_map.png"
                           Stretch="Uniform"
                           SizeChanged="MapImage_SizeChanged"/>

                    <Canvas x:Name="MapOverlay"
                            Background="Transparent"
                            IsHitTestVisible="True">
                        <ItemsControl ItemsSource="{Binding TradeRouteVisuals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Polyline StrokeThickness="1.5">
                                        <Polyline.Style>
                                            <Style TargetType="Polyline">
                                                <Setter Property="Stroke" Value="#668B6F47"/>
                                                <Setter Property="StrokeThickness" Value="1.5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFDAA520"/>
                                                        <Setter Property="StrokeThickness" Value="2.8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Polyline.Style>
                                        <Polyline.ToolTip>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="Маршрут: "/><Run Text="{Binding DisplayName}"/><LineBreak/>
                                                <Run Text="Объём недели:"/><LineBreak/>
                                                <Run Text="Еда: "/><Run Text="{Binding WeeklyFoodMoved}"/><LineBreak/>
                                                <Run Text="Ресурсы: "/><Run Text="{Binding WeeklyResourcesMoved}"/><LineBreak/>
                                                <Run Text="Товары: "/><Run Text="{Binding WeeklyGoodsMoved}"/><LineBreak/>
                                                <Run Text="Всего: "/><Run Text="{Binding TotalWeeklyVolume}"/>
                                            </TextBlock>
                                        </Polyline.ToolTip>
                                        <Polyline.Points>
                                            <MultiBinding Converter="{StaticResource TradeRoutePointsToPointCollectionConverter}">
                                                <Binding Path="Points"/>
                                                <Binding ElementName="MapContainer" Path="ActualWidth"/>
                                                <Binding ElementName="MapImage" Path="ActualWidth"/>
                                                <Binding ElementName="MapContainer" Path="ActualHeight"/>
                                                <Binding ElementName="MapImage" Path="ActualHeight"/>
                                            </MultiBinding>
                                        </Polyline.Points>
                                    </Polyline>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Polyline Stroke="#FF00B7FF" StrokeThickness="2.5" StrokeDashArray="2,2" IsHitTestVisible="False">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource TradeRoutePointsToPointCollectionConverter}">
                                    <Binding Path="EditedTradeRoutePolylinePoints"/>
                                    <Binding ElementName="MapContainer" Path="ActualWidth"/>
                                    <Binding ElementName="MapImage" Path="ActualWidth"/>
                                    <Binding ElementName="MapContainer" Path="ActualHeight"/>
                                    <Binding ElementName="MapImage" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>

                        <ItemsControl ItemsSource="{Binding EditedTradeRoutePoints}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value><MultiBinding Converter="{StaticResource MapMarkerCanvasLeftConverter}"><Binding Path="X"/><Binding ElementName="MapContainer" Path="ActualWidth"/><Binding ElementName="MapImage" Path="ActualWidth"/></MultiBinding></Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value><MultiBinding Converter="{StaticResource MapMarkerCanvasTopConverter}"><Binding Path="Y"/><Binding ElementName="MapContainer" Path="ActualHeight"/><Binding ElementName="MapImage" Path="ActualHeight"/></MultiBinding></Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="8" Height="8" Fill="#FF00B7FF" Stroke="#FFFFFFFF" StrokeThickness="1" ToolTip="{Binding X}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding ActiveCaravanMovementMarkers}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource CaravanMarkerCanvasCoordinateConverter}" ConverterParameter="X">
                                                <Binding Path="Points"/>
                                                <Binding Path="Progress"/>
                                                <Binding ElementName="MapContainer" Path="ActualWidth"/>
                                                <Binding ElementName="MapImage" Path="ActualWidth"/>
                                                <Binding ElementName="MapContainer" Path="ActualHeight"/>
                                                <Binding ElementName="MapImage" Path="ActualHeight"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource CaravanMarkerCanvasCoordinateConverter}" ConverterParameter="Y">
                                                <Binding Path="Points"/>
                                                <Binding Path="Progress"/>
                                                <Binding ElementName="MapContainer" Path="ActualWidth"/>
                                                <Binding ElementName="MapImage" Path="ActualWidth"/>
                                                <Binding ElementName="MapContainer" Path="ActualHeight"/>
                                                <Binding ElementName="MapImage" Path="ActualHeight"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="10" Height="10" Fill="#FFB22222" Stroke="#FFFCECC9" StrokeThickness="1" ToolTip="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding SettlementMapMarkers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MapMarkerCanvasLeftConverter}">
                                                <Binding Path="X"/>
                                                <Binding ElementName="MapContainer" Path="ActualWidth"/>
                                                <Binding ElementName="MapImage" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MapMarkerCanvasTopConverter}">
                                                <Binding Path="Y"/>
                                                <Binding ElementName="MapContainer" Path="ActualHeight"/>
                                                <Binding ElementName="MapImage" Path="ActualHeight"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="22"
                                            Height="22"
                                            Command="{Binding DataContext.SelectSettlementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding SettlementId}"
                                            ToolTip="{Binding DisplayName}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsHitTestVisible="True">
                                        <Grid>
                                            <Ellipse Fill="#66FFAA00" Stroke="#CCFFAA00" StrokeThickness="2">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Width" Value="14"/>
                                                        <Setter Property="Height" Value="14"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Width" Value="18"/>
                                                                <Setter Property="Height" Value="18"/>
                                                                <Setter Property="StrokeThickness" Value="3"/>
                                                                <Setter Property="Fill" Value="#99FFD166"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="5" Height="5" Fill="#FFFFAA00"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Редактор маршрутов" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
                        <CheckBox Content="Режим разметки маршрутов" IsChecked="{Binding IsTradeRouteAuthoringModeEnabled}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding TradeRoutes}" SelectedItem="{Binding SelectedTradeRouteForAuthoring}" DisplayMemberPath="Id" Margin="0,0,0,8"/>
                        <TextBlock Text="Расстояние / дней пути:" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SelectedTradeRouteDistanceDaysInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Text="Кликайте по дороге на карте, чтобы добавить точки маршрута" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Отменить точку" Command="{Binding UndoTradeRoutePointCommand}" Margin="0,0,8,0"/>
                            <Button Content="Очистить" Command="{Binding ClearTradeRoutePointsCommand}" Margin="0,0,8,0"/>
                            <Button Content="Сохранить" Command="{Binding SaveTradeRoutePointsCommand}" Margin="0,0,8,0"/>
                            <Button Content="Скопировать Points" Command="{Binding CopyTradeRoutePointsCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding EditedTradeRoutePointCount, StringFormat=Точек: {0}}"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding SimulationSummaryTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SimulationSummaryDayAndHour}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryCityState}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryFoodBalance}" ToolTip="{Binding FoodBalanceTooltip}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryActiveEvents}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryRandomEventsStatus}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedRegionName, StringFormat=Регион: {0}}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryLastImportantChange}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="Выбранный город" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedCityName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Тип/профиль:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedCityProfile}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="Состояние города:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CityStateDisplay}" Margin="0,0,0,6"/>

                        <TextBlock Text="Население:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Population}" Margin="0,0,0,6"/>

                        <TextBlock Text="Ресурсы:" FontWeight="SemiBold" ToolTip="{Binding ResourcesTooltip}"/>
                        <TextBlock Text="{Binding Resources}" ToolTip="{Binding ResourcesTooltip}" Margin="0,0,0,6"/>

                        <TextBlock Text="Товары:" FontWeight="SemiBold" ToolTip="{Binding GoodsTooltip}"/>
                        <TextBlock Text="{Binding Goods}" ToolTip="{Binding GoodsTooltip}" Margin="0,0,0,6"/>

                        <TextBlock Text="Пища:" FontWeight="SemiBold" ToolTip="{Binding FoodBalanceTooltip}"/>
                        <TextBlock Text="{Binding Food}" ToolTip="{Binding FoodBalanceTooltip}" Margin="0,0,0,6"/>

                        <TextBlock Text="Безопасность:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Security}" Margin="0,0,0,6"/>

                        <TextBlock Text="Преступность:" FontWeight="SemiBold" ToolTip="{Binding CrimeFlowTooltip}"/>
                        <TextBlock Text="{Binding Crime}" ToolTip="{Binding CrimeFlowTooltip}" Margin="0,0,0,6"/>

                        <TextBlock Text="Настроение:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Mood}" Margin="0,0,0,12"/>

                        <WrapPanel>
                            <Button Content="Открыть город" Width="130" Command="{Binding OpenSelectedCityCommand}" Click="OpenCityButton_Click" Margin="0,0,8,0"/>
                            <Button Content="Открыть летопись города" Width="140" Click="OpenLogButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Отладка карты" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="{Binding MapCalibrationToggleButtonText}" Command="{Binding ToggleMapCalibrationModeCommand}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LastMapCalibrationPointDisplay}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
