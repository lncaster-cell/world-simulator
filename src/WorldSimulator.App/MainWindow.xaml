<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="World Simulator"
        Height="520"
        Width="860">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="World Simulator MVP 0.1"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Day:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Hour:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="State:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Start" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Pause" Command="{Binding PauseCommand}" Width="90"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Gotha" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="City Name:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CityName}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="City State:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CityState}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Population:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Population}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Food:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Food}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Wealth:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Wealth}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Mood:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Mood}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Security:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding Security}"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Crime:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding Crime}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Resources:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding Resources}"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Goods:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="9" Grid.Column="2" Text="{Binding Goods}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
