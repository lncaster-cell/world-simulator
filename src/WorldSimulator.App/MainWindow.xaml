<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симулятор мира MVP 0.1"
        Height="720"
        Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="День:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Час:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="Состояние:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Старт" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Пауза" Command="{Binding PauseCommand}" Width="90" Margin="0,0,16,0"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Загрузить" Command="{Binding LoadCommand}" Width="110"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid x:Name="MapContainer"
                      MouseLeftButtonDown="MapContainer_MouseLeftButtonDown"
                      SizeChanged="MapContainer_SizeChanged">
                    <Image x:Name="MapImage"
                           Source="/Assets/Maps/world_map.png"
                           Stretch="Uniform"
                           SizeChanged="MapImage_SizeChanged"/>

                    <Canvas x:Name="MapOverlay"
                            Background="Transparent"
                            IsHitTestVisible="True">
                        <Button x:Name="GothaHotspotButton"
                                Width="34"
                                Height="34"
                                Command="{Binding SelectGothaCommand}"
                                ToolTip="Гота"
                                Background="Transparent"
                                BorderThickness="0"
                                IsHitTestVisible="True">
                            <Grid>
                                <Ellipse Width="18"
                                         Height="18"
                                         Fill="#66FFAA00"
                                         Stroke="#CCFFAA00"
                                         StrokeThickness="2"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="#FFFFAA00"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Canvas>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding SimulationSummaryTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SimulationSummaryDayAndHour}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryCityState}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryFoodBalance}" ToolTip="{Binding FoodBalanceTooltip}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryActiveEvents}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryRandomEventsStatus}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SimulationSummaryLastImportantChange}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsGothaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Выбранный город" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedCityName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Тип/профиль:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedCityProfile}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="Состояние города:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CityStateDisplay}" Margin="0,0,0,6"/>

                        <TextBlock Text="Население:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Population}" Margin="0,0,0,6"/>

                        <TextBlock Text="Пища:" FontWeight="SemiBold" ToolTip="{Binding FoodBalanceTooltip}"/>
                        <TextBlock Text="{Binding Food}" ToolTip="{Binding FoodBalanceTooltip}" Margin="0,0,0,6"/>

                        <TextBlock Text="Безопасность:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Security}" Margin="0,0,0,6"/>

                        <TextBlock Text="Преступность:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Crime}" Margin="0,0,0,6"/>

                        <TextBlock Text="Настроение:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Mood}" Margin="0,0,0,12"/>

                        <WrapPanel>
                            <Button Content="Открыть город" Width="130" Command="{Binding OpenSelectedCityCommand}" Click="OpenCityButton_Click" Margin="0,0,8,0"/>
                            <Button Content="Открыть летопись города" Width="140" Click="OpenLogButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Отладка карты" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="{Binding MapCalibrationToggleButtonText}" Command="{Binding ToggleMapCalibrationModeCommand}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LastMapCalibrationPointDisplay}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
