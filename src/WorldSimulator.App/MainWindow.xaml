<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="World Simulator"
        Height="720"
        Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Day:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Hour:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="State:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Start" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Pause" Command="{Binding PauseCommand}" Width="90"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid>
                    <Image Source="/Assets/Maps/world_map.png" Stretch="Uniform"/>

                    <!-- TODO: Convert fixed hotspot coordinates to a relative map coordinate model after MVP. -->
                    <Button Width="58"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,122,154,0"
                            Command="{Binding SelectGothaCommand}"
                            ToolTip="Gotha"
                            Background="#55FFAA00"
                            BorderBrush="#AAFFAA00"
                            BorderThickness="1"
                            Opacity="0.75"
                            Content="" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsGothaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Selected City" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedCityName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Type/Profile:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedCityProfile}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="City State:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CityState}" Margin="0,0,0,6"/>

                        <TextBlock Text="Population:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Population}" Margin="0,0,0,6"/>

                        <TextBlock Text="Food:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Food}" Margin="0,0,0,6"/>

                        <TextBlock Text="Security:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Security}" Margin="0,0,0,6"/>

                        <TextBlock Text="Crime:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Crime}" Margin="0,0,0,6"/>

                        <TextBlock Text="Mood:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Mood}" Margin="0,0,0,12"/>

                        <Button Content="Open City" Width="130" Command="{Binding OpenSelectedCityCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Gotha Overview" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="City Name:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CityName}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="City State:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CityState}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Population:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Population}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Food:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Food}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Wealth:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Wealth}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Mood:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Mood}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Security:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding Security}"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Crime:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding Crime}"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Resources:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding Resources}"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Goods:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="9" Grid.Column="2" Text="{Binding Goods}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
