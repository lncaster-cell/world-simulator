<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симулятор мира MVP 0.1"
        Height="720"
        Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="День:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Час:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="Состояние:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Старт" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Пауза" Command="{Binding PauseCommand}" Width="90"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid>
                    <Image Source="/Assets/Maps/world_map.png" Stretch="Uniform"/>

                    <!-- TODO: Convert fixed hotspot coordinates to a relative map coordinate model after MVP. -->
                    <Button Width="58"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,122,154,0"
                            Command="{Binding SelectGothaCommand}"
                            ToolTip="Гота"
                            Background="#55FFAA00"
                            BorderBrush="#AAFFAA00"
                            BorderThickness="1"
                            Opacity="0.75"
                            Content="" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsGothaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Выбранный город" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedCityName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Тип/профиль:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedCityProfile}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="Состояние города:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CityStateDisplay}" Margin="0,0,0,6"/>

                        <TextBlock Text="Население:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Population}" Margin="0,0,0,6"/>

                        <TextBlock Text="Пища:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Food}" Margin="0,0,0,6"/>

                        <TextBlock Text="Безопасность:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Security}" Margin="0,0,0,6"/>

                        <TextBlock Text="Преступность:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Crime}" Margin="0,0,0,6"/>

                        <TextBlock Text="Настроение:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Mood}" Margin="0,0,0,12"/>

                        <Button Content="Открыть город" Width="130" Command="{Binding OpenSelectedCityCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        Padding="12"
                        CornerRadius="6"
                        Visibility="{Binding IsCityPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabControl SelectedIndex="{Binding SelectedCityTabIndex}">
                        <TabItem Header="Обзор">
                            <StackPanel Margin="8">
                                <TextBlock Text="Обзор города Гота" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Город:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CityName}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Профиль города:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SelectedCityProfile}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Состояние города:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding CityStateDisplay}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Население:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Population}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Настроение:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Mood}"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Безопасность:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Security}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Преступность:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding Crime}"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="День:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding Day}"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Час:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding Hour}"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Состояние симуляции:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="9" Grid.Column="2" Text="{Binding SimulationState}"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Запасы">
                            <StackPanel Margin="8">
                                <TextBlock Text="Текущие запасы" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="Пища:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Food}" Margin="0,0,0,6"/>
                                <TextBlock Text="Богатство:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Wealth}" Margin="0,0,0,6"/>
                                <TextBlock Text="Ресурсы:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Resources}" Margin="0,0,0,6"/>
                                <TextBlock Text="Товары:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Goods}" Margin="0,0,0,10"/>
                                <TextBlock Text="Значения запасов в MVP указаны в условных единицах."
                                           FontStyle="Italic"
                                           Foreground="DimGray"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Потоки">
                            <StackPanel Margin="8">
                                <TextBlock Text="Дневной пищевой баланс (preview)" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <TextBlock Text="Начальная пища:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodStartingFood}" Margin="0,0,0,6"/>

                                <TextBlock Text="Потребление населения:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodPopulationConsumptionDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Рыбалка:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodFishingIncomeDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Охота:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodHuntingIncomeDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Поставки с материка:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodMainlandSupplyIncomeDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Влияние событий:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodEventDeltaDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Дневной баланс:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodTotalDeltaDisplay}" Margin="0,0,0,6"/>

                                <TextBlock Text="Ожидаемая пища после дня:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DailyFoodEndingFood}" Margin="0,0,0,6"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="События">
                            <StackPanel Margin="8">
                                <TextBlock Text="Активных событий пока нет." TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Журнал">
                            <StackPanel Margin="8">
                                <TextBlock Text="Игровой журнал" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Технический журнал" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Журнал будет реализован позже." TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Отладка">
                            <StackPanel Margin="8">
                                <Border BorderBrush="DarkOrange" BorderThickness="1" Padding="8" CornerRadius="4" Background="#FFFFF7E6">
                                    <TextBlock Text="Инструменты отладки пока не реализованы и предназначены только для разработки." 
                                               TextWrapping="Wrap"
                                               Foreground="DarkRed"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
