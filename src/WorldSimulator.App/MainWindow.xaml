<Window x:Class="WorldSimulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WorldSimulator.App.Views"
        Title="Симулятор мира MVP 0.1"
        Height="720"
        Width="1200">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="День:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Day}" Margin="0,0,16,0"/>

                <TextBlock Text="Час:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding Hour}" Margin="0,0,16,0"/>

                <TextBlock Text="Состояние:" FontWeight="SemiBold"/>
                <TextBlock Text=" " />
                <TextBlock Text="{Binding SimulationState}" Margin="0,0,16,0"/>

                <Button Content="Старт" Command="{Binding StartCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Пауза" Command="{Binding PauseCommand}" Width="90" Margin="0,0,8,0"/>
                <Button Content="Сброс" Command="{Binding ResetCommand}" Width="90" Margin="0,0,16,0" ToolTip="Сбросить симуляцию к дню 1, часу 0 без перезапуска приложения"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="110" Margin="0,0,8,0"/>
                <Button Content="Загрузить" Command="{Binding LoadCommand}" Width="110" Margin="0,0,8,0"/>
                <CheckBox Content="Показать маршруты"
                          IsChecked="{Binding WorldMap.IsTradeRoutesOverlayVisible}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"/>
                <CheckBox Content="Debug: реальные пути караванов"
                          IsChecked="{Binding WorldMap.IsLoadedRoutePathsDebugVisible}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"/>
                <ToggleButton Content="Редактор маршрутов" IsChecked="{Binding IsTradeRouteAuthoringModeEnabled}" Width="160"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <views:TradeRouteAuthoringPanelView Grid.Row="0" Grid.ColumnSpan="3" />
            <views:WorldMapView Grid.Row="1" Grid.Column="0" />

            <StackPanel Grid.Row="1" Grid.Column="2">
                <views:SimulationSummaryView />
                <views:SelectedCityPanelView />
                <views:MapDebugPanelView />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
