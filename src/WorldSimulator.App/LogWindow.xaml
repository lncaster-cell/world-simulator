<Window x:Class="WorldSimulator.App.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding CityJournalTitle}"
        Width="900"
        Height="600"
        MinWidth="700"
        MinHeight="400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="{Binding CityJournalTitle}"
                   FontWeight="SemiBold"
                   FontSize="18"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="3"
                   Text="История состояния, населения, событий и ресурсов города."
                   Foreground="DimGray"
                   Margin="0,0,0,10"/>

        <ComboBox Grid.Row="2"
                  Grid.ColumnSpan="3"
                  Width="220"
                  Margin="0,0,0,10"
                  DisplayMemberPath="Title"
                  ItemsSource="{Binding Journal.SimulationJournalFilters}"
                  SelectedItem="{Binding Journal.SelectedSimulationJournalFilter}"/>

        <DataGrid x:Name="SimulationJournalGrid"
                  Grid.Row="3"
                  Grid.Column="0"
                  ItemsSource="{Binding Journal.FilteredSimulationJournalEntries}"
                  SelectedItem="{Binding Journal.SelectedSimulationJournalEntry, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip" Value="{Binding DayTooltip}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="День" Binding="{Binding Day}" Width="60"/>
                <DataGridTextColumn Header="Состояние" Binding="{Binding CityState}" Width="120"/>
                <DataGridTextColumn Header="Население" Binding="{Binding PopulationDisplay}" Width="110"/>
                <DataGridTemplateColumn Header="Пища" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FoodDeltaDisplay}" ToolTip="{Binding FoodTooltip}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="События" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ActiveEventsCount}" ToolTip="{Binding EventsTooltip}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Кратко" Binding="{Binding Summary}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Grid.Column="2" BorderThickness="1" BorderBrush="#DDD" Padding="10">
            <ContentControl Content="{Binding Journal.SelectedSimulationJournalEntry}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Day, StringFormat=День {0}}"/>
                                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Итог:"/>
                                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Пища:"/>
                                        <TextBlock Text="{Binding FoodStart, StringFormat={}{0:0.##}}"/>
                                        <TextBlock Text="{Binding FoodEnd, StringFormat=→ {0:0.##}}"/>
                                        <TextBlock Text="{Binding FoodDeltaDisplay, StringFormat=Баланс: {0}}"/>
                                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Расчёт:"/>
                                        <TextBlock Text="{Binding FoodCalculation}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="Выберите день в журнале." Foreground="DimGray"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>
    </Grid>
</Window>
