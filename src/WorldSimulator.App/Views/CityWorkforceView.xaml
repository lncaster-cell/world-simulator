<UserControl x:Class="WorldSimulator.App.Views.CityWorkforceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorldSimulator.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <TextBlock Text="Рабочая сила города"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Население"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <ItemsControl ItemsSource="{Binding WorkforcePopulationRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CityWorkforceRowViewModel}">
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Value}"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,8,0,10"/>

            <TextBlock Text="Трудоспособные"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <ItemsControl ItemsSource="{Binding WorkforceCalculationRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CityWorkforceRowViewModel}">
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Value}"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,8,0,10"/>

            <TextBlock Text="Распределение по секторам"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <TextBlock Text="{Binding WorkforceAllocationStatus}"
                       Foreground="DimGray"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding WorkforceAllocationRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CityWorkforceRowViewModel}">
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Value}"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,8,0,10"/>

            <TextBlock Text="Локальные лимиты секторов"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <ItemsControl ItemsSource="{Binding WorkforceCapacityRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CityWorkforceRowViewModel}">
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Value}"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
