<UserControl x:Class="WorldSimulator.App.Views.CityInfrastructureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorldSimulator.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <TextBlock Text="{Binding CityName, StringFormat=Инфраструктура города {0}}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding CityInfrastructureRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CityInfrastructureRowViewModel}">
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Level, StringFormat=Уровень: {0}/5}" Margin="0,2,0,2"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Уровни 1–5 пока являются базовым состоянием без бонусов. В будущих фазах события и развитие города смогут повышать или снижать эти уровни."
                       FontStyle="Italic"
                       Foreground="DimGray"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
