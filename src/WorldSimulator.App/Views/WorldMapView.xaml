<UserControl x:Class="WorldSimulator.App.Views.WorldMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorldSimulator.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MapViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Resources/WorldMapLayerTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8">
        <Grid x:Name="MapContainer"
              MouseLeftButtonDown="MapContainer_MouseLeftButtonDown"
              SizeChanged="MapContainer_SizeChanged">
            <Image x:Name="MapImage"
                   Source="/Assets/Maps/world_map.png"
                   Stretch="Uniform"
                   SizeChanged="MapImage_SizeChanged" />
            <Image x:Name="RoutesMapImage"
                   Source="/Assets/Maps/world_map_routes.png"
                   Stretch="Uniform"
                   IsHitTestVisible="False"
                   Visibility="{Binding IsTradeRoutesOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Canvas x:Name="MapOverlay"
                    Background="Transparent"
                    IsHitTestVisible="True"
                    Tag="{Binding ElementName=MapImage}">
                <ItemsControl ItemsSource="{Binding DebugLoadedRoutePathVisuals}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemTemplate="{StaticResource DebugLoadedRoutePathTemplate}"
                              Visibility="{Binding IsLoadedRoutePathsDebugVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ItemsControl ItemsSource="{Binding DebugLoadedRoutePathVisuals}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemContainerStyle="{StaticResource DebugRouteLabelContainerStyle}"
                              ItemTemplate="{StaticResource DebugRouteLabelTemplate}"
                              IsHitTestVisible="False"
                              Visibility="{Binding IsLoadedRoutePathsDebugVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ItemsControl ItemsSource="{Binding TradeRouteVisuals}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemTemplate="{StaticResource TradeRoutePolylineTemplate}"
                              Visibility="Collapsed" />

                <Path Style="{StaticResource AuthoringRoutePathStyle}" />
                <Polyline Style="{StaticResource AuthoringRouteOverlayPolylineStyle}" />

                <ItemsControl ItemsSource="{Binding Tag.TradeRouteAuthoring.EditedTradeRoutePoints, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemContainerStyle="{StaticResource AuthoringRoutePointContainerStyle}"
                              ItemTemplate="{StaticResource AuthoringRoutePointTemplate}"
                              Visibility="{Binding Tag.TradeRouteAuthoring.IsTradeRouteAuthoringModeEnabled, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ItemsControl ItemsSource="{Binding ActiveCaravanMovementMarkers}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemContainerStyle="{StaticResource ActiveCaravanMarkerContainerStyle}"
                              ItemTemplate="{StaticResource ActiveCaravanMarkerTemplate}" />

                <ItemsControl ItemsSource="{Binding SettlementMapMarkers}"
                              Style="{StaticResource WorldMapLayerItemsControlStyle}"
                              ItemContainerStyle="{StaticResource SettlementMapMarkerContainerStyle}"
                              ItemTemplate="{StaticResource SettlementMapMarkerTemplate}" />
            </Canvas>
        </Grid>
    </Border>
</UserControl>
